{
  "variables": {
    "COMPONENTS_DIR": "src/components",
    "ATOMS_DIR": "src/components/atoms",
    "MOLECULES_DIR": "src/components/molecules",
    "ORGANISMS_DIR": "src/components/organisms",
    "PROVIDERS_DIR": "src/components/providers",
    "APP_DIR": "src/app",
    "TYPES_FILE": "src/types/index.ts"
  },
  "patterns": [
    {
      "onManual": "rundev",
      "manualTitle": "🚀 Run dev",
      "notify": [
        {
          "commands": ["pnpm run dev"],
          "description": "🚀 Run dev"
        }
      ],
      "description": "🚀 Run dev"
    },
    {
      "id": "atom-created",
      "onCreateFile": "src/components/atoms/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/index.ts",
          "description": "📦 Export atom {{TRIGGER_NAME}} in main export"
        },
        {
          "commands": [
            "npx jest src/components/atoms/{{TRIGGER_NAME}}.test.tsx"
          ],
          "description": "🧪 Create test file"
        }
      ],
      "description": "⚛️ New atom {{TRIGGER_NAME}} created",
      "showInlineHint": true
    },
    {
      "id": "molecule-created",
      "onCreateFile": "src/components/molecules/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/index.ts",
          "description": "📦 Export molecule {{TRIGGER_NAME}} in main export"
        }
      ],
      "description": "🧬 New molecule {{TRIGGER_NAME}} created",
      "showInlineHint": true
    },
    {
      "id": "organism-created",
      "onCreateFile": "src/components/organisms/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/index.ts",
          "description": "📦 Export organism {{TRIGGER_NAME}} in main export"
        }
      ],
      "description": "🦠 New organism {{TRIGGER_NAME}} created",
      "showInlineHint": true
    },
    {
      "id": "provider-created",
      "onCreateFile": "src/components/providers/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/providers/index.ts",
          "description": "📦 Add export for provider {{TRIGGER_NAME}}"
        },
        {
          "file": "src/components/index.ts",
          "description": "📦 Export provider {{TRIGGER_NAME}} in main export"
        }
      ],
      "description": "🔌 New provider {{TRIGGER_NAME}} created",
      "showInlineHint": true
    },
    {
      "id": "component-modified",
      "onChange": "src/components/**/*.tsx",
      "notify": [
        {
          "file": "src/components/index.ts",
          "description": "📦 Verify that {{TRIGGER_NAME}} is exported in the hierarchy"
        }
      ],
      "description": "🔧 Component {{TRIGGER_NAME}} modified",
      "showInlineHint": false
    },
    {
      "id": "layout-modified",
      "onChange": "src/app/layout.tsx",
      "notify": [
        {
          "file": "src/app/globals.css",
          "description": "🎨 Check global CSS variables"
        },
        {
          "file": "tailwind.config.ts",
          "description": "⚙️ Sync Tailwind configuration"
        }
      ],
      "description": "📐 Layout modified - check styles",
      "showInlineHint": true
    },
    {
      "id": "globals-css-modified",
      "onChange": "src/app/globals.css",
      "notify": [
        {
          "file": "tailwind.config.ts",
          "description": "🔄 Sync CSS variables with Tailwind"
        }
      ],
      "description": "🎨 Global CSS variables modified",
      "showInlineHint": true
    },
    {
      "id": "tailwind-config-modified",
      "onChange": "tailwind.config.ts",
      "notify": [
        {
          "file": "src/app/globals.css",
          "description": "🎨 Verify that CSS variables match"
        },
        {
          "commands": ["pnpm run build"],
          "description": "🔨 Test build after config modification"
        }
      ],
      "description": "⚙️ Tailwind configuration modified",
      "showInlineHint": true
    }
  ]
}
