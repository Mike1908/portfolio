{
  "variables": {
    "COMPONENTS_DIR": "src/components",
    "ATOMS_DIR": "src/components/atoms",
    "MOLECULES_DIR": "src/components/molecules",
    "ORGANISMS_DIR": "src/components/organisms",
    "PROVIDERS_DIR": "src/components/providers",
    "APP_DIR": "src/app",
    "TYPES_FILE": "src/types/index.ts"
  },
  "patterns": [
    {
      "id": "atom-created",
      "onCreateFile": "src/components/atoms/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/atoms/index.ts",
          "description": "📦 Ajouter l'export pour l'atom {{TRIGGER_NAME}}"
        },
        {
          "file": "src/components/index.ts",
          "description": "📦 Exposer l'atom {{TRIGGER_NAME}} dans l'export principal"
        }
      ],
      "description": "⚛️ Nouvel atom {{TRIGGER_NAME}} créé",
      "showInlineHint": true
    },
    {
      "id": "molecule-created",
      "onCreateFile": "src/components/molecules/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/molecules/index.ts",
          "description": "📦 Ajouter l'export pour la molecule {{TRIGGER_NAME}}"
        },
        {
          "file": "src/components/index.ts",
          "description": "📦 Exposer la molecule {{TRIGGER_NAME}} dans l'export principal"
        }
      ],
      "description": "🧬 Nouvelle molecule {{TRIGGER_NAME}} créée",
      "showInlineHint": true
    },
    {
      "id": "organism-created",
      "onCreateFile": "src/components/organisms/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/organisms/index.ts",
          "description": "📦 Ajouter l'export pour l'organism {{TRIGGER_NAME}}"
        },
        {
          "file": "src/components/index.ts",
          "description": "📦 Exposer l'organism {{TRIGGER_NAME}} dans l'export principal"
        }
      ],
      "description": "🦠 Nouvel organism {{TRIGGER_NAME}} créé",
      "showInlineHint": true
    },
    {
      "id": "provider-created",
      "onCreateFile": "src/components/providers/**/*.{tsx,ts}",
      "notify": [
        {
          "file": "src/components/providers/index.ts",
          "description": "📦 Ajouter l'export pour le provider {{TRIGGER_NAME}}"
        },
        {
          "file": "src/components/index.ts",
          "description": "📦 Exposer le provider {{TRIGGER_NAME}} dans l'export principal"
        }
      ],
      "description": "🔌 Nouveau provider {{TRIGGER_NAME}} créé",
      "showInlineHint": true
    },
    {
      "id": "component-modified",
      "onChange": "src/components/**/*.tsx",
      "notify": [
        {
          "file": "src/components/index.ts",
          "description": "📦 Vérifier que {{TRIGGER_NAME}} est exporté dans la hiérarchie"
        }
      ],
      "description": "🔧 Composant {{TRIGGER_NAME}} modifié",
      "showInlineHint": false
    },
    {
      "id": "layout-modified",
      "onChange": "src/app/layout.tsx",
      "notify": [
        {
          "file": "src/app/globals.css",
          "description": "🎨 Vérifier les variables CSS globales"
        },
        {
          "file": "tailwind.config.ts",
          "description": "⚙️ Synchroniser la configuration Tailwind"
        }
      ],
      "description": "📐 Layout modifié - vérifier les styles",
      "showInlineHint": true
    },
    {
      "id": "globals-css-modified",
      "onChange": "src/app/globals.css",
      "notify": [
        {
          "file": "tailwind.config.ts",
          "description": "🔄 Synchroniser les variables CSS avec Tailwind"
        }
      ],
      "description": "🎨 Variables CSS globales modifiées",
      "showInlineHint": true
    },
    {
      "id": "tailwind-config-modified",
      "onChange": "tailwind.config.ts",
      "notify": [
        {
          "file": "src/app/globals.css",
          "description": "🎨 Vérifier que les variables CSS correspondent"
        },
        {
          "commands": ["pnpm run build"],
          "description": "🔨 Tester le build après modification de config"
        }
      ],
      "description": "⚙️ Configuration Tailwind modifiée",
      "showInlineHint": true
    }
  ]
}
